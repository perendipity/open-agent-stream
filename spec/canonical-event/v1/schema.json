{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-agent-stream.dev/spec/canonical-event/v1/schema.json",
  "title": "CanonicalEvent",
  "type": "object",
  "required": [
    "event_version",
    "event_id",
    "source_type",
    "source_instance_id",
    "session_key",
    "sequence",
    "timestamp",
    "kind",
    "actor",
    "context",
    "payload",
    "raw_ref"
  ],
  "properties": {
    "event_version": { "type": "integer", "const": 1 },
    "event_id": { "type": "string" },
    "source_type": { "type": "string" },
    "source_instance_id": { "type": "string" },
    "session_key": { "type": "string" },
    "sequence": { "type": "integer", "minimum": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "kind": { "type": "string" },
    "actor": {
      "type": "object",
      "required": ["kind", "name"],
      "properties": {
        "kind": { "type": "string" },
        "name": { "type": "string" }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "required": ["source_type"],
      "properties": {
        "source_type": { "type": "string" },
        "project_key": { "type": "string" },
        "project_locator": { "type": "string" },
        "source_session_key": { "type": "string" },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "payload": { "type": "object" },
    "raw_ref": {
      "type": "object",
      "required": ["ledger_offset", "envelope_id"],
      "properties": {
        "ledger_offset": { "type": "integer", "minimum": 1 },
        "envelope_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "parse_status": { "type": "string" }
  },
  "additionalProperties": false
}

