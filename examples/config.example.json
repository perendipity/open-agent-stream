{
  "version": "0.1",
  "machine_id": "example-machine",
  "state_path": ".open-agent-stream/state.db",
  "ledger_path": ".open-agent-stream/ledger.db",
  "max_storage_bytes": 104857600,
  "prune_target_bytes": 83886080,
  "min_free_bytes": 52428800,
  "batch_size": 64,
  "poll_interval": "3s",
  "error_backoff": "10s",
  "max_consecutive_errors": 10,
  "sources": [
    {
      "instance_id": "codex-local",
      "type": "codex_local",
      "root": "./fixtures/sources/codex"
    },
    {
      "instance_id": "claude-local",
      "type": "claude_local",
      "root": "./fixtures/sources/claude"
    }
  ],
  "sinks": [
    {
      "id": "stdout",
      "type": "stdout",
      "options": {}
    },
    {
      "id": "remote-http",
      "type": "http",
      "settings": {
        "url": "https://collector.example.invalid/ingest",
        "method": "POST",
        "format": "oas_batch_json",
        "bearer_token_env": "OAS_REMOTE_TOKEN",
        "headers": {
          "X-OAS-Example": "remote-http"
        }
      },
      "delivery": {
        "max_batch_events": 10,
        "max_batch_age": "2s",
        "retry_initial_backoff": "2s",
        "retry_max_backoff": "30s",
        "poison_after_failures": 5
      }
    }
  ],
  "privacy": {
    "default": {
      "drop_raw": false,
      "redact_keys": ["api_key", "token", "secret"],
      "regexes": [
        {
          "pattern": "Bearer\\s+[A-Za-z0-9._-]+",
          "replacement": "Bearer [REDACTED]"
        }
      ]
    },
    "per_sink": {
      "stdout": {
        "drop_raw": false,
        "redact_keys": ["api_key", "token", "secret"]
      },
      "remote-http": {
        "drop_raw": false,
        "redact_keys": ["api_key", "token", "secret"]
      }
    }
  }
}
