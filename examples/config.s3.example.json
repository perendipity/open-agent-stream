{
  "version": "0.1",
  "machine_id": "example-s3",
  "state_path": ".open-agent-stream/state.db",
  "ledger_path": ".open-agent-stream/ledger.db",
  "max_storage_bytes": 104857600,
  "prune_target_bytes": 83886080,
  "min_free_bytes": 52428800,
  "batch_size": 64,
  "poll_interval": "3s",
  "error_backoff": "10s",
  "max_consecutive_errors": 10,
  "sources": [
    {
      "instance_id": "codex-local",
      "type": "codex_local",
      "root": "./fixtures/sources/codex"
    },
    {
      "instance_id": "claude-local",
      "type": "claude_local",
      "root": "./fixtures/sources/claude"
    }
  ],
  "sinks": [
    {
      "id": "archive-s3",
      "type": "s3",
      "settings": {
        "bucket": "oas-example-bucket",
        "region": "us-west-2",
        "prefix": "collector/",
        "key_template": "{prefix}{sink_id}/{batch_id}.jsonl.gz",
        "storage_class": "STANDARD",
        "server_side_encryption": "AES256"
      },
      "delivery": {
        "max_batch_events": 1000,
        "max_batch_age": "1m",
        "retry_initial_backoff": "5s",
        "retry_max_backoff": "2m",
        "poison_after_failures": 5
      }
    }
  ],
  "privacy": {
    "default": {
      "drop_raw": false,
      "redact_keys": ["api_key", "token", "secret"],
      "regexes": [
        {
          "pattern": "Bearer\\s+[A-Za-z0-9._-]+",
          "replacement": "Bearer [REDACTED]"
        }
      ]
    },
    "per_sink": {
      "archive-s3": {
        "drop_raw": false,
        "redact_keys": ["api_key", "token", "secret"]
      }
    }
  }
}
